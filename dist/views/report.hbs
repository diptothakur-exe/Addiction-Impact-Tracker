<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/tailwind.css" />
</head>
<body class="min-h-screen bg-zinc-950 px-4 py-8">

  <div class="w-full max-w-md mx-auto space-y-5">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
      ← Back to tracker
    </a>

    <!-- Risk summary card -->
    <div class="card">
      <div class="flex items-start justify-between mb-3">
        <div>
          <span
            class="risk-badge text-xs"
            style="background:{{riskBg}};color:{{riskColor}}"
          >{{riskLevel}} RISK</span>
          <div class="text-4xl font-semibold mt-2 text-zinc-100">{{score}}<span class="text-xl text-zinc-500">/100</span></div>
          <div class="text-xs text-zinc-500 mt-1">Estimated range: {{scoreLo}}–{{scoreHi}} (±10%, approximate)</div>
        </div>
        <div class="text-right text-xs text-zinc-600">
          <div>{{typeLabel}}</div>
          <div>{{intensity}} {{intensityLabel}}</div>
          <div>{{years}} years</div>
        </div>
      </div>

      <!-- Damage meter -->
      <div class="mt-4">
        <div class="flex justify-between text-xs text-zinc-500 mb-1.5">
          <span>Damage meter</span><span>{{score}}%</span>
        </div>
        <div class="w-full h-2.5 bg-zinc-800 rounded-full overflow-hidden">
          <div
            class="meter-fill h-full rounded-full"
            style="width:{{score}}%;background:{{meterColor}}"
          ></div>
        </div>
        <div class="flex justify-between text-xs text-zinc-700 mt-1">
          <span>0 — Safe</span><span>100 — Severe</span>
        </div>
      </div>
    </div>

    <!-- Affected areas -->
    <div class="card">
      <h2 class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-4">Affected areas</h2>
      <div class="space-y-3">
        {{#each affectedParts}}
        <div>
          <div class="flex justify-between text-sm mb-1.5">
            <span class="text-zinc-300">{{name}}</span>
            <span class="text-zinc-500 text-xs">{{pct}}%</span>
          </div>
          <div class="w-full h-1.5 bg-zinc-800 rounded-full overflow-hidden">
            <div class="part-bar" style="width:{{pct}}%;background:{{color}}"></div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    <!-- Metrics -->
    <div class="grid grid-cols-2 gap-3">
      <div class="stat-card">
        <div class="text-xs text-zinc-500 mb-1">Health index</div>
        <div class="text-2xl font-semibold text-zinc-100">{{healthIndex}}<span class="text-sm text-zinc-500">/100</span></div>
      </div>
      <div class="stat-card">
        <div class="text-xs text-zinc-500 mb-1">Dependency</div>
        <div class="text-2xl font-semibold text-zinc-100">{{dependency}}</div>
      </div>
      <div class="stat-card">
        <div class="text-xs text-zinc-500 mb-1">Risk score</div>
        <div class="text-2xl font-semibold text-zinc-100">{{score}}<span class="text-sm text-zinc-500">/100</span></div>
      </div>
      {{#if monthlyCost}}
      <div class="stat-card">
        <div class="text-xs text-zinc-500 mb-1">Est. monthly cost</div>
        <div class="text-xl font-semibold text-zinc-100">₹{{monthlyCost}}</div>
      </div>
      {{else}}
      <div class="stat-card">
        <div class="text-xs text-zinc-500 mb-1">Est. monthly cost</div>
        <div class="text-xl font-semibold text-zinc-500">—</div>
      </div>
      {{/if}}
    </div>

    <!-- Projection chart -->
    <div class="card">
      <h2 class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-1">Risk projection</h2>
      <div class="flex gap-4 text-xs text-zinc-500 mb-4">
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-6 h-0.5 bg-red-500 rounded"></span>Continue
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-6 h-0.5 bg-emerald-500 rounded border-t-2 border-dashed border-emerald-500" style="height:0;margin-top:1px"></span>Quit today
        </span>
      </div>
      <div style="position:relative;height:200px;width:100%">
        <canvas id="proj-chart"
          role="img"
          aria-label="Line chart showing risk score over 5 years: continue (upward) vs quit today (downward)"
        >Risk projection data for continue and quit scenarios over 5 years.</canvas>
      </div>
    </div>

    <!-- Future projections text -->
    <div class="card space-y-3">
      <h2 class="text-xs font-medium text-zinc-400 uppercase tracking-wide">Future projections</h2>
      <div class="text-sm text-zinc-400 border-b border-zinc-800 pb-3">{{proj1yr}}</div>
      <div class="text-sm text-zinc-400 border-b border-zinc-800 pb-3">{{proj5yr}}</div>
      <div class="text-sm text-zinc-400">{{projQuit}}</div>
    </div>

    <!-- Recovery timeline -->
    <div class="card">
      <h2 class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-4">Recovery timeline (if quit today)</h2>
      <div class="grid grid-cols-4 gap-2">
        {{#each recoveryPoints}}
        <div class="bg-zinc-800/50 rounded-xl p-3 text-center border border-zinc-700/30">
          <div class="text-xs text-zinc-500 mb-1">{{period}}</div>
          <div class="text-lg font-semibold text-emerald-400">{{score}}</div>
        </div>
        {{/each}}
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="px-4 py-3 bg-zinc-900/50 border border-zinc-800 rounded-xl text-xs text-zinc-600 leading-relaxed">
      This is an estimated assessment based on general population data, not medical advice.
      Consult a qualified healthcare professional for personal guidance.
    </div>

    <a href="/" class="btn-primary block text-center">
      ← New assessment
    </a>

  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <script>
    const labels   = {{{chartLabels}}};
    const contData = {{{chartContinue}}};
    const quitData = {{{chartQuit}}};

    new Chart(document.getElementById('proj-chart'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Continue',
            data: contData,
            borderColor: '#ef4444',
            backgroundColor: 'rgba(239,68,68,0.07)',
            borderWidth: 2,
            pointRadius: 3,
            pointBackgroundColor: '#ef4444',
            tension: 0.35,
            fill: true,
          },
          {
            label: 'Quit today',
            data: quitData,
            borderColor: '#10b981',
            backgroundColor: 'rgba(16,185,129,0.06)',
            borderWidth: 2,
            borderDash: [6, 3],
            pointRadius: 3,
            pointBackgroundColor: '#10b981',
            tension: 0.35,
            fill: true,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${c.parsed.y}` } },
        },
        scales: {
          y: {
            min: 0, max: 100,
            grid: { color: 'rgba(255,255,255,0.05)' },
            ticks: { color: '#52525b', stepSize: 25 },
          },
          x: {
            grid: { display: false },
            ticks: { color: '#52525b' },
          },
        },
      },
    });
  </script>
</body>
</html>
